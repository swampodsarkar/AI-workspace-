# ========== AI Workspace Environment Variables ==========

# --- App ---
PORT=3001
CLIENT_URL=http://localhost:5173
SITE_URL=http://localhost:5173
NODE_ENV=development

# --- Firebase Client (Web SDK) ---
# These are public keys safe to include in the frontend
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# --- Firebase Admin (Server-side - for auth verification) ---
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
# Optional: for token verification (leave empty to skip verification)
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# --- OpenRouter AI ---
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Stripe (optional) ---
VITE_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- bKash (Bangladesh) ---
BKASH_MERCHANT_NUMBER=01XXXXXXXXX
BKASH_APP_KEY=your-bkash-app-key
BKASH_APP_SECRET=your-bkash-app-secret

# --- Nagad (Bangladesh) ---
NAGAD_MERCHANT_ID=your-nagad-merchant-id
NAGAD_MERCHANT_KEY=your-nagad-merchant-key

# --- Usage Limits ---
FREE_DAILY_LIMIT=50
